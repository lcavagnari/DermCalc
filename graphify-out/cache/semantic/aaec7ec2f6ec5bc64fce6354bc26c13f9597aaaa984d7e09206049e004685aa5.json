{"nodes": [{"id": "claude_md", "label": "CLAUDE.md Project Documentation", "file_type": "document", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "dermcalc_app", "label": "DermCalc Android Application", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Android app for dermatological score calculation and patient management, built with Jetpack Compose, Kotlin, Material3. Entry point: MainActivity detects orientation and delegates to portrait/landscape activities."}, {"id": "gradle_build", "label": "Gradle Build System", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Version catalog only (libs.xxx from libs.versions.toml), FAIL_ON_PROJECT_REPOS enforces central repo management, non-transitive R class, JUnit 4 only. Android project built with Gradle wrapper."}, {"id": "onboarding_flow", "label": "Onboarding Flow", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-page pager for patient profile input (name, DOB, sex, height, weight). Gated by OnboardingModel.hasSeenOnboarding. All values stored in SI units; imperial converted on write."}, {"id": "pasi_calculator", "label": "PASI Score Calculator", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-step calculator across four districts (head, upper limbs, trunk, lower limbs) with erythema, induration, desquamation and area scoring. Severity: Mild <10, Moderate 10-20, Severe >=20."}, {"id": "easi_calculator", "label": "EASI Score Calculator", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Identical structure to PASI with adjusted parameters: erythema, oedema/papulation, excoriation, lichenification on 0-3 scale."}, {"id": "history_feature", "label": "Calculation History Log", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chronological log of all calculations with type, value, severity and date. In-memory only (Room dependency present, persistence not yet implemented). Full history screen with deletion when entries exceed 7."}, {"id": "ci_pipeline", "label": "GitHub Actions CI Pipeline", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Five parallel jobs on push/PR to master: validate-wrapper, unit-test, instrumented-test (API 24+34 emulator matrix), dependency-check (OWASP, CVSS>=7.0 fails), lint. All except validate-wrapper depend on it."}, {"id": "security_framework", "label": "Security Lint Rules", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Seven lint rules at error severity: HardcodedDebugMode, SetWorldReadable, SetWorldWritable, UnsafeNativeCodeLocation, AllowBackup, ExportedReceiver, ExportedContentProvider. Pre-existing findings in lint-baseline.xml. OWASP dependency-check fails on CVSS >= 7.0."}], "edges": [{"source": "claude_md", "target": "dermcalc_app", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": null, "weight": 1.0}, {"source": "claude_md", "target": "gradle_build", "relation": "references", "confidence": "EXTRACTED", "con